# ---------- Ollama (100% local LLM, no external API keys) ----------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3
OLLAMA_STREAM=false

# ---------- Database ----------
# Local dev default = SQLite (zero setup). Switch to Postgres for production.
DATABASE_URL=sqlite:///./storage/codemind.db
# DATABASE_URL=postgresql://codemind:codemind@localhost:5432/codemind

# ---------- Vector store (Chroma, persisted to local disk) ----------
CHROMA_PERSIST_DIR=./storage/chroma_db

# ---------- Embeddings (runs fully on-device via sentence-transformers) ----------
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---------- Repo indexing ----------
MAX_FILE_SIZE_KB=500
CHUNK_MAX_LINES=120
CHUNK_OVERLAP_LINES=15

# ---------- GitHub (optional, only needed to clone private repos) ----------
GITHUB_TOKEN=
